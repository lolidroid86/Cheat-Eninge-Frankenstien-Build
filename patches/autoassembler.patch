+procedure processAAIfdefBlocks(code: TStrings; is64bit: boolean);
+// Preprocesses {$ifdef SYMBOL}/{$ifndef SYMBOL}/{$endif} directives in AA scripts.
+// Blanks lines inside conditionally-excluded blocks. Runs before aobscans so
+// that excluded AOBSCAN lines are also skipped.
+// NOTE: pre-scans DEFINE() lines for user symbols; a DEFINE inside a skipped
+// block will still be seen (limitation, acceptable for typical usage).
+const
+  MAXNEST = 64;
+var
+  i, a, b, skipDepth, nskip: integer;
+  currentline, sym: string;
+  definedNames: TStringList;
+  skipStack: array[0..MAXNEST-1] of boolean;
+begin
+  definedNames := TStringList.Create;
+  try
+    definedNames.CaseSensitive := false;
+
+    // Built-in platform defines
+    {$ifdef windows}
+    definedNames.Add('WINDOWS');
+    {$endif}
+    if is64bit then
+    begin
+      definedNames.Add('CPU64');
+      definedNames.Add('WIN64');
+    end else begin
+      definedNames.Add('CPU32');
+      definedNames.Add('WIN32');
+    end;
+
+    // Pre-scan for user DEFINE(name, ...) to collect symbol names
+    for i := 0 to code.Count-1 do
+    begin
+      currentline := uppercase(trim(code[i]));
+      if copy(currentline, 1, 7) = 'DEFINE(' then
+      begin
+        a := pos('(', currentline);
+        b := pos(',', currentline);
+        if (a > 0) and (b > 0) then
+          definedNames.Add(trim(copy(currentline, a+1, b-a-1)));
+      end;
+    end;
+
+    FillChar(skipStack, SizeOf(skipStack), 0);
+    skipDepth := 0;
+    nskip := 0;
+
+    i := 0;
+    while i < code.Count do
+    begin
+      currentline := uppercase(trim(code[i]));
+
+      if currentline = '{$ENDIF}' then
+      begin
+        if skipDepth > 0 then
+        begin
+          if skipStack[skipDepth] then dec(nskip);
+          dec(skipDepth);
+        end;
+        code[i] := '';
+        inc(i);
+        continue;
+      end;
+
+      if currentline = '{$ELSE}' then
+      begin
+        code[i] := '';
+        if skipDepth > 0 then
+        begin
+          // Only flip if no outer level is causing the skip
+          if nskip - ord(skipStack[skipDepth]) = 0 then
+          begin
+            if skipStack[skipDepth] then
+            begin
+              skipStack[skipDepth] := false;
+              dec(nskip);
+            end else begin
+              skipStack[skipDepth] := true;
+              inc(nskip);
+            end;
+          end;
+        end;
+        inc(i);
+        continue;
+      end;
+
+      if copy(currentline, 1, 8) = '{$IFDEF ' then
+      begin
+        if skipDepth < MAXNEST-1 then
+        begin
+          inc(skipDepth);
+          sym := trim(copy(currentline, 9, length(currentline)-9));
+          if (length(sym) > 0) and (sym[length(sym)] = '}') then
+            sym := trim(copy(sym, 1, length(sym)-1));
+          if (nskip > 0) or (definedNames.IndexOf(sym) < 0) then
+          begin
+            skipStack[skipDepth] := true;
+            inc(nskip);
+          end else
+            skipStack[skipDepth] := false;
+        end;
+        code[i] := '';
+        inc(i);
+        continue;
+      end;
+
+      if copy(currentline, 1, 9) = '{$IFNDEF ' then
+      begin
+        if skipDepth < MAXNEST-1 then
+        begin
+          inc(skipDepth);
+          sym := trim(copy(currentline, 10, length(currentline)-10));
+          if (length(sym) > 0) and (sym[length(sym)] = '}') then
+            sym := trim(copy(sym, 1, length(sym)-1));
+          if (nskip > 0) or (definedNames.IndexOf(sym) >= 0) then
+          begin
+            skipStack[skipDepth] := true;
+            inc(nskip);
+          end else
+            skipStack[skipDepth] := false;
+        end;
+        code[i] := '';
+        inc(i);
+        continue;
+      end;
+
+      if nskip > 0 then
+        code[i] := '';
+
+      inc(i);
+    end;
+  finally
+    definedNames.Free;
+  end;
+end;
